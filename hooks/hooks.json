{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "msgbox peek"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 660000,
            "command": "msgbox wait"
          }
        ]
      }
    ]
  }
}
